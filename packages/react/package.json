{
  "name": "@mkatogui/uds-react",
  "version": "0.3.0",
  "description": "React components for Universal Design System — 32 accessible components, 9 palettes, 496 tokens",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/styles/*.css dist/ && cat dist/tokens.css dist/components.css > dist/styles.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^19.2.4",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "accessibility",
    "wcag",
    "tokens",
    "universal-design-system"
  ],
  "author": "Marcelo Katogui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkatogui/universal-design-system.git",
    "directory": "packages/react"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
