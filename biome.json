{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "useSemanticElements": "warn",
        "useFocusableInteractive": "warn",
        "useAriaPropsForRole": "warn",
        "useKeyWithClickEvents": "warn",
        "useButtonType": "warn",
        "noSvgWithoutTitle": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "noStaticElementInteractions": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noPrototypeBuiltins": "warn"
      },
      "complexity": {
        "noForEach": "warn"
      },
      "correctness": {
        "noSelfAssign": "warn",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "files": {
    "includes": [
      "**/cli/src/**",
      "**/packages/react/src/**",
      "**/src/mcp/**/*.ts",
      "**/packages/tokens/build.js",
      "**/tests/components/**",
      "**/style-dictionary.config.mjs",
      "**/vitest.config.ts",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/docs",
      "!**/coverage",
      "!**/.scannerwork",
      "!**/.claude/worktrees"
    ]
  }
}
