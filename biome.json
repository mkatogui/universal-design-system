{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "useSemanticElements": "warn",
        "useFocusableInteractive": "warn",
        "useAriaPropsForRole": "warn",
        "useKeyWithClickEvents": "warn",
        "useButtonType": "warn",
        "noSvgWithoutTitle": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "noStaticElementInteractions": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noPrototypeBuiltins": "warn",
        "noExplicitAny": "warn"
      },
      "complexity": {
        "noForEach": "warn"
      },
      "correctness": {
        "noSelfAssign": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["tests/**", "**/*.test.js", "**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "complexity": { "noForEach": "off" },
          "correctness": { "noSelfAssign": "off" },
          "style": { "noNonNullAssertion": "off" }
        }
      }
    },
    {
      "includes": ["**/*.css"],
      "linter": { "rules": { "style": { "noDescendingSpecificity": "off" } } }
    },
    {
      "includes": ["**/Carousel/Carousel.tsx", "**/OTPInput/OTPInput.tsx"],
      "linter": { "rules": { "suspicious": { "noArrayIndexKey": "off" } } }
    }
  ],
  "files": {
    "includes": [
      "**/cli/src/**",
      "**/packages/react/src/**",
      "**/src/mcp/**/*.ts",
      "**/packages/tokens/build.js",
      "**/tests/components/**",
      "**/style-dictionary.config.mjs",
      "**/vitest.config.ts",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/docs",
      "!**/coverage",
      "!**/.scannerwork",
      "!**/.claude/worktrees"
    ]
  }
}
