{
  "name": "universal-design-system",
  "version": "0.1.0",
  "description": "A production-grade design system with 9 structural palettes, 31 components, and automated WCAG 2.1 AA compliance. Reverse-engineered from 100 modern websites.",
  "main": "tokens/design-tokens.json",
  "bin": {
    "uds": "./cli/dist/index.js"
  },
  "scripts": {
    "build": "style-dictionary build",
    "build:cli": "cd cli && npx tsc",
    "prepublishOnly": "npm run build:cli",
    "validate": "python3 scripts/validate-tokens.py",
    "audit": "python3 scripts/wcag-audit.py",
    "verify": "python3 scripts/verify-docs.py --file docs/docs.html",
    "check": "npm run validate && npm run audit && npm run verify",
    "search": "python3 src/scripts/search.py",
    "generate": "python3 src/scripts/design_system.py",
    "sync-data": "python3 src/data/_sync_all.py"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "css-custom-properties",
    "wcag",
    "accessibility",
    "figma",
    "style-dictionary",
    "components",
    "ui",
    "claude-code",
    "cursor",
    "windsurf",
    "ai-coding",
    "bm25",
    "reasoning-engine"
  ],
  "author": "Marcelo Katogui",
  "license": "MIT",
  "devDependencies": {
    "style-dictionary": "^4.0.0"
  },
  "files": [
    "tokens/",
    "docs/",
    "audits/",
    "src/",
    "cli/dist/",
    ".claude/skills/",
    "SPECIFICATION.md",
    "SKILL.md",
    "CLAUDE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mkatogui/universal-design-system"
  },
  "claude-plugin": {
    "marketplace": "mkatogui/universal-design-system",
    "install": "universal-design-system"
  }
}
