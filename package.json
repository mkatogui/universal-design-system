{
  "name": "@mkatogui/universal-design-system",
  "version": "0.3.1",
  "description": "A production-grade design system with 9 structural palettes, 32 components, and automated WCAG 2.1 AA compliance. Deterministic UI recommendation engine powered by retrieval and rule evaluation.",
  "main": "tokens/design-tokens.json",
  "bin": {
    "uds": "cli/dist/index.js"
  },
  "scripts": {
    "build": "style-dictionary build --config style-dictionary.config.mjs",
    "build:cli": "cd cli && npm install && npx tsc",
    "prepublishOnly": "npm run build:cli",
    "validate": "python3 scripts/validate-tokens.py",
    "audit": "python3 scripts/wcag-audit.py",
    "verify": "python3 scripts/verify-docs.py --file docs/docs.html",
    "check": "npm run validate && npm run audit && npm run verify",
    "search": "python3 src/scripts/search.py",
    "generate": "python3 src/scripts/design_system.py",
    "sync-data": "python3 src/data/_sync_all.py",
    "inject-palettes": "python3 scripts/inject-custom-palettes.py",
    "palette": "python3 src/scripts/palette.py",
    "build:react": "cd packages/react && npm run build",
    "build:tokens": "cd packages/tokens && node build.js",
    "audit:axe": "node scripts/axe-audit.js",
    "audit:apca": "python3 scripts/apca-audit.py",
    "test:a11y": "node scripts/axe-audit.js",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "storybook": "npx storybook dev -p 6006",
    "build:storybook": "npx storybook build -o docs/storybook",
    "test:contracts": "python3 -m unittest discover tests/contracts/ -v",
    "test:react": "vitest run",
    "test:react:coverage": "vitest run --coverage",
    "test:primitives": "node --test tests/components/primitives.test.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "css-custom-properties",
    "wcag",
    "accessibility",
    "figma",
    "style-dictionary",
    "components",
    "ui",
    "claude-code",
    "cursor",
    "windsurf",
    "ai-coding",
    "bm25",
    "reasoning-engine",
    "mcp",
    "headless",
    "primitives",
    "react",
    "vue",
    "svelte",
    "tailwindcss",
    "apca",
    "wcag-3"
  ],
  "author": "Marcelo Katogui",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.30.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "style-dictionary": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "tokens/",
    "docs/",
    "audits/",
    "src/data/",
    "src/scripts/",
    "src/mcp/index.js",
    "src/mcp/package.json",
    "src/mcp/README.md",
    "cli/dist/",
    ".claude/skills/",
    "SPECIFICATION.md",
    "SKILL.md",
    "CLAUDE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkatogui/universal-design-system.git"
  },
  "claude-plugin": {
    "marketplace": "mkatogui/universal-design-system",
    "install": "universal-design-system"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.json": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
